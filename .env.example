# ── Service ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3010

# CORS: the admin console origin(s) allowed to call this API with credentials.
# Comma-separated. Must be exact origins (no wildcard when credentials are used).
ADMIN_CONSOLE_ORIGIN=http://localhost:5273

# Set to false ONLY when this service runs behind the nginx gateway (the gateway
# owns CORS then). Leave true for direct access (own public domain) and local dev.
ADMIN_CORS_ENABLED=true

# ── Database (admin-owned tables) ─────────────────────────────────────────────
# Use DATABASE_URL (Railway Postgres) OR the discrete DB_* vars.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=parkingslot_admin_service
DB_SSL=false
TYPEORM_LOGGING=false

# ── Shared domain database (read-only) ────────────────────────────────────────
# The marketplace/finance/dashboard modules read real data (listings, bookings,
# payments, payouts, reviews, users, wallet) from the shared domain DB that the
# other microservices write to. Defaults to the DB_* host above with the
# database name below; set UPSTREAM_DATABASE_URL to point somewhere else.
UPSTREAM_DB_NAME=parkslot
UPSTREAM_DATABASE_URL=

# ── Admin auth (JWT) ──────────────────────────────────────────────────────────
# Short-lived access token + longer-lived refresh token (httpOnly cookie).
ADMIN_JWT_SECRET=change-me-access-secret
ADMIN_JWT_ACCESS_TTL=900            # seconds (15m)
ADMIN_REFRESH_SECRET=change-me-refresh-secret
ADMIN_REFRESH_TTL=2592000          # seconds (30d)
# Set true to require the refresh cookie be marked Secure (HTTPS). Keep false for local http.
ADMIN_COOKIE_SECURE=false

# ── Default super-admin (created/updated by `npm run seed`) ───────────────────
ADMIN_SEED_EMAIL=admin@parkingslot.com
ADMIN_SEED_PASSWORD=admin
ADMIN_SEED_NAME=Super Admin

# ── Downstream domain services (BFF wiring — used as modules are wired up) ─────
# Base URLs of the existing microservices. Stub modules ignore these for now.
USER_SERVICE_BASE_URL=
LISTING_SERVICE_BASE_URL=
BOOKING_SERVICE_BASE_URL=
PAYMENT_SERVICE_BASE_URL=
PAYOUT_SERVICE_BASE_URL=
REVIEW_SERVICE_BASE_URL=
KYC_SERVICE_BASE_URL=
CHAT_SERVICE_BASE_URL=
NOTIFICATION_SERVICE_BASE_URL=
# Shared secret for internal service-to-service calls (x-internal-token).
INTERNAL_API_SECRET=replace-me
